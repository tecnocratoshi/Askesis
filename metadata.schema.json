{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "description": { "type": "string" },
    "requestFramePermissions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["name", "version", "description"]
}