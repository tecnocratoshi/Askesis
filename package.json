{
  "_comment": "[ANALYSIS PROGRESS]: 100% - Dependências verificadas e alinhadas com os requisitos do sistema.",
  "name": "habit-tracker-ai-vercel",
  "version": "1.0.0",
  "description": "A dynamic habit tracker with data visualization and personalized AI-powered feedback.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "node build.js",
    "build": "NODE_ENV=production node build.js",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:test",
    "lint": "npm run typecheck",
    "guardrail:security-html": "node scripts/guardrail-security-html.js",
    "guardrail:locales": "node scripts/guardrail-locales-parity.js",
    "guardrail:audit": "node scripts/guardrail-audit.js",
    "guardrail:sw-manifest": "node scripts/check-sw-manifest.js",
    "guardrail:all": "npm run guardrail:security-html && npm run guardrail:locales && npm run guardrail:audit && npm run guardrail:sw-manifest",
    "test": "npm run guardrail:all && vitest run",
    "check:deps": "bash scripts/check-vite.sh",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:scenario": "vitest run tests/scenario-test-*.test.ts",
    "lint:style": "stylelint \"css/**/*.css\" --allow-empty-input",
    "lint:style:fix": "stylelint \"css/**/*.css\" --allow-empty-input --fix",
    "validate:metadata": "node scripts/validate-json.js metadata.json",
    "guardrail:l3-l4": "npm run validate:metadata && npm run lint:style",
    "guardrail:l3-l4:fix": "npm run validate:metadata && npm run lint:style:fix"
  },
  "prepare": "husky install",
  "lint-staged": {
    "css/**/*.css": [
      "stylelint --fix",
      "git add"
    ],
    "metadata.json": [
      "node scripts/validate-json.js metadata.json"
    ]
  },
  "keywords": [
    "habit-tracker",
    "pwa",
    "stoicism",
    "ai",
    "vercel"
  ],
  "author": "AI-Powered Engineer",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@upstash/redis": "^1.36.2",
    "@vercel/speed-insights": "^2.0.0",
    "dompurify": "^3.3.3"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  },
  "devDependencies": {
    "@types/dompurify": "^2.3.3",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "esbuild": "^0.27.3",
    "fast-check": "^3.5.0",
    "happy-dom": "^20.4.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "stylelint": "^15.0.0",
    "stylelint-config-standard": "^31.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vitest": "^4.1.2",
    "workbox-build": "^7.0.0"
  }
}
